using System;

class Program
{
    static void Main()
    {
        int opcion;

        Console.WriteLine("=== MENU DE SERVICIOS DE LA CLINICA ===");
        Console.WriteLine("1. Consulta");
        Console.WriteLine("2. Laboratorio");
        Console.WriteLine("3. Rayos X");
        Console.WriteLine("4. Farmacia");
        Console.WriteLine("5. Salir");
        Console.Write("Seleccione una opcion: ");

        opcion = int.Parse(Console.ReadLine());

        switch (opcion)
        {
            case 1:
                Console.WriteLine("Servicio: Consulta medica");
                Console.WriteLine("Precio: $52.500");
                Console.WriteLine("Tiempo de espera: 20 minutos");
                break;

            case 2:
                Console.WriteLine("Servicio: Laboratorio");
                Console.WriteLine("Precio: $34.000");
                Console.WriteLine("Tiempo de espera: 40 minutos");
                break;

            case 3:
                Console.WriteLine("Servicio: Rayos X");
                Console.WriteLine("Precio: $87.400");
                Console.WriteLine("Tiempo de espera: 30 minutos");
                break;

            case 4:
                Console.WriteLine("Servicio: Farmacia");
                Console.WriteLine("Precio: Depende del medicamento");
                Console.WriteLine("Tiempo de espera: 7 minutos");
                break;

            case 5:
                Console.WriteLine("Gracias por usar el sistema. ¡Hasta luego!");
                break;

            default:
                Console.WriteLine("Opcion invalida. Por favor seleccione una opcion del 1 al 5.");
                break;
        }

        Console.ReadKey();
    }
}
