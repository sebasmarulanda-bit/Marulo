using System;
class Program
{
    static void Main()
    {
        int turno;
        string continuar = "S";

        while (continuar.ToUpper() == "S")
        {
            Console.Write("Ingrese numero de turno (mayor a 0): ");
            turno = int.Parse(Console.ReadLine());

            while (turno <= 0)
            {
                Console.WriteLine("Error: El numero de turno debe ser mayor a 0.");
                Console.Write("Ingrese nuevamente el numero de turno: ");
                turno = int.Parse(Console.ReadLine());
            }

            Console.WriteLine("Turno registrado correctamente: " + turno);

            Console.Write("Desea continuar? (S/N): ");
            continuar = Console.ReadLine();
        }

        Console.WriteLine("Sistema finalizado.");
    }
}
